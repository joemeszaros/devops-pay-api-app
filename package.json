{
  "name": "pay-api-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Simplified pay-api sample for Chapter 12 DevOps workflows.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.check.json --noEmit",
    "test": "node --import tsx --test",
    "test:coverage": "c8 --temp-directory /tmp/pay-api-app-c8 --reports-dir /tmp/pay-api-app-coverage --exclude src/index.ts --exclude src/telemetry.ts --reporter=text --reporter=lcov --lines 80 --functions 80 --branches 70 --statements 80 node --import tsx --test"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.66.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "c8": "^10.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
